# ================================
# BANCO DE DADOS
# ================================
# URI de conexão com o MongoDB
# Exemplo local: mongodb://localhost:27017/insta-automation
# Exemplo Atlas: mongodb+srv://usuario:senha@cluster.mongodb.net/insta-automation
MONGO_URI=mongodb://localhost:27017/insta-automation

# ================================
# SERVIDOR
# ================================
# Porta em que o backend vai rodar (padrão: 3000)
PORT=3000

# ================================
# REDIS (BullMQ)
# ================================
# Host do Redis (padrão: 127.0.0.1)
REDIS_HOST=127.0.0.1

# Porta do Redis (padrão: 6379)
REDIS_PORT=6379

# ================================
# META / INSTAGRAM GRAPH API  (obrigatório para publicar Reels)
# ================================
# Crie um app em developers.facebook.com → Meu App → Configurações Básicas
META_APP_ID=SEU_APP_ID
META_APP_SECRET=SEU_APP_SECRET

# Mesmos valores acima — usados no fluxo Instagram Business Login
INSTAGRAM_APP_ID=SEU_APP_ID
INSTAGRAM_APP_SECRET=SEU_APP_SECRET

# URL pública deste servidor (o Instagram baixa o vídeo desta URL para processar o Reel)
# Em produção: use o IP/domínio real. Em dev: use ngrok ou similar.
# Exemplo: PUBLIC_URL=http://123.45.67.89:3000
PUBLIC_URL=http://SEU_IP_PUBLICO:3000

# URI de callback do OAuth (deve bater exatamente com o configurado no Meta App)
OAUTH_REDIRECT_URI=http://138.121.238.235:3000/api/oauth/callback

# ================================
# PUPPETEER / AUTOMAÇÃO
# ================================
# true = roda o navegador invisível (produção)
# false = roda o navegador visível (desenvolvimento/debug)
HEADLESS=false
