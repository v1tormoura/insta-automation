# ================================
# BANCO DE DADOS
# ================================
# URI de conexão com o MongoDB
# Exemplo local: mongodb://localhost:27017/insta-automation
# Exemplo Atlas: mongodb+srv://usuario:senha@cluster.mongodb.net/insta-automation
MONGO_URI=mongodb://localhost:27017/insta-automation

# ================================
# SERVIDOR
# ================================
# Porta em que o backend vai rodar (padrão: 3000)
PORT=3000

# ================================
# REDIS (BullMQ)
# ================================
# Host do Redis (padrão: 127.0.0.1)
REDIS_HOST=127.0.0.1

# Porta do Redis (padrão: 6379)
REDIS_PORT=6379

# ================================
# PUPPETEER / AUTOMAÇÃO
# ================================
# true = roda o navegador invisível (produção)
# false = roda o navegador visível (desenvolvimento/debug)
HEADLESS=false
